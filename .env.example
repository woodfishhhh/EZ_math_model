# ez-math-model — 外部工具环境变量样例
#
# 用法：把本文件复制为 ~/.ezmm.env（或手动写入用户级环境变量），不要提交到 git。
# 全部变量统一前缀 EZMM_。详见 references/external-tools-catalog.md。

# === 1. PDF 解析 ===

# MinerU 云 API token（注册免费领取，超额才付费）
# 不填也完全可用：仓库优先调本地 CLI（pip install mineru，开源免费），
# 或直接用网页 flash（mineru.net，零注册）
EZMM_MINERU_TOKEN=

# === 2. 学术搜索 ===

# OpenAlex 邮箱（可选；填了能提升 API 配额）
EZMM_OPENALEX_EMAIL=

# Semantic Scholar API key（可选；填了配额翻倍）
EZMM_S2_API_KEY=

# SerpAPI key —— 通过它访问 Google Scholar / Baidu Scholar / Google
EZMM_SERPAPI_KEY=

# === 3. 数据集 ===

# Kaggle API token：建议用 ~/.kaggle/kaggle.json 而非 env var；本变量预留
# EZMM_KAGGLE_USERNAME=
# EZMM_KAGGLE_KEY=

# HuggingFace token（私有数据集需要；公开数据集留空即可）
EZMM_HF_TOKEN=

# === 4. 网页抓取 ===

# Firecrawl key（爬取行业 / 政策类网站）
EZMM_FIRECRAWL_KEY=

# Tavily key（LLM-friendly 搜索 + 摘要）
EZMM_TAVILY_KEY=

# Exa key（神经搜索）
EZMM_EXA_KEY=
