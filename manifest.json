  "external": {
    "zhanwen_mathmodel": {
      "upstream": "https://github.com/zhanwen/MathModel",
      "local_dir": "skills/ez-math-model/external/zhanwen-mathmodel",
      "fetch_strategy": "git clone --depth 1 --filter=blob:none --sparse",
      "sparse_paths": [
        "国赛论文/",
        "国赛试题/",
        "美赛论文/",
        "2024年数模悉知&论文模版/",
        "2025年数模悉知&论文模版/",
        "2024年最终获奖名单/",
        "数学建模Latex模版/",
        "README.md"
      ],
      "marker_files": {
        "complete": "skills/ez-math-model/external/zhanwen-mathmodel/.complete",
        "failed": "skills/ez-math-model/external/zhanwen-mathmodel/.failed",
        "skip": "skills/ez-math-model/external/zhanwen-mathmodel/.skip"
      },
      "license_note": "上游内容版权归原作者所有，仅供本机学术参考；不复制不分发不入库。"
    },
    "paper_orchestra": {
      "upstream": "https://github.com/Ar9av/PaperOrchestra",
      "local_dir": "skills/ez-math-model/external/paper-orchestra",
      "adapter": "skills/ez-math-model/tools/paper-orchestra/SKILL.md",
      "entrypoint": "skills/ez-math-model/external/paper-orchestra/skills/paper-orchestra/SKILL.md",
      "used_by": "writer",
      "mode": "default PaperOrchestra-first writer route with EZMM Markdown compatibility output",
      "license_note": "MIT; keep upstream LICENSE and CITATION.cff and cite PaperOrchestra when its workflow shapes the final paper."
    },
    "tools_decisions": {
      "local_dir": "skills/ez-math-model/external/tools",
      "marker_files": {
        "setup_state": "skills/ez-math-model/external/tools/setup_state.json",
        "decided": "skills/ez-math-model/external/tools/.tools_decided",
        "domain_pattern": "skills/ez-math-model/external/tools/<domain>.{free,skip,yes}",
        "agent_mode_pattern": "skills/ez-math-model/external/tools/agent_mode.{single,multi,hybrid}",
        "inherited_skills_pattern": "skills/ez-math-model/external/tools/inherited_skills.{yes,recommended,skip}"
      },
      "domains": ["pdf", "scholar", "dataset", "webcrawl", "corpus", "agent_mode", "inherited_skills"]
    },
    "user_corpus": {
      "local_dir": "skills/ez-math-model/external/user-corpus",
      "explorer_doc": "skills/ez-math-model/tools/user-corpus-explorer/SKILL.md",
      "runtime_outputs": {
        "agents_md": "skills/ez-math-model/external/user-corpus/AGENTS.md",
        "cache": "skills/ez-math-model/external/user-corpus/.corpus_index.json"
      },
      "note": "用户自带参考资料，由 corpus explorer subagent 在 pipeline 01 末尾扫描产出 AGENTS.md。runtime_outputs 是运行时才产出的文件，不在仓库初始静态资产中。"
    }
  },
  "env_example": "skills/ez-math-model/.env.example"
}
